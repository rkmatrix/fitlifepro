# FitLife Environment Variables
# Copy this to .env and fill in your keys

# Supabase (get from https://supabase.com/dashboard → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenAI (get from https://platform.openai.com/api-keys)
EXPO_PUBLIC_OPENAI_API_KEY=your-openai-key

# YouTube Data API v3 (get from https://console.cloud.google.com)
EXPO_PUBLIC_YOUTUBE_API_KEY=your-youtube-key

# USDA FoodData Central (get from https://fdc.nal.usda.gov/api-guide.html)
# DEMO_KEY works for testing (60 requests/hour)
EXPO_PUBLIC_USDA_API_KEY=DEMO_KEY
